# Configuração do Plano de Comunicação - Novacap ASCOM
# Copie este arquivo para .env e preencha os valores

# Senha mestre para login no sistema
MASTER_PASSWORD=coloque_uma_senha_forte_aqui

# Chave secreta para criptografia AES-256-CBC das API Keys no banco
# ATENÇÃO: Se alterar esta chave, dados criptografados existentes serão perdidos!
APP_SECRET=coloque_32_caracteres_aleatorios_aqui

# Chave secreta para assinatura de tokens JWT (autenticação)
# ATENÇÃO: Se alterar, todos os tokens existentes serão invalidados!
JWT_SECRET=coloque_outro_secret_aqui

# Porta do servidor (opcional, padrão 3001)
PORT=3001

# Nível de log: debug, info, warn, error
LOG_LEVEL=info
